# Absolute path to the directory containing video files to process
SOURCE_DIR=/mnt/downloads

# Absolute path to the movies output directory
MOVIES_DIR=/mnt/movies

# Absolute path to the TV series output directory
SERIES_DIR=/mnt/tv

